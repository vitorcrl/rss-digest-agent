# --- Banco de dados ---
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/digest_db

# --- Claude API ---
ANTHROPIC_API_KEY=sk-ant-...
AI_RELEVANCE_MODEL=claude-haiku-4-5-20251001
AI_SUMMARY_MODEL=claude-sonnet-4-6
AI_MIN_RELEVANCE_SCORE=6
AI_MAX_ARTICLES_PER_DIGEST=10

# --- Delivery RSS (Parte 1) ---
DELIVERY_WEBHOOK_URL=https://hooks.slack.com/...
DELIVERY_RETRY_ATTEMPTS=3
DIGEST_CRON_HOUR=7
DIGEST_CRON_TIMEZONE=America/Sao_Paulo

# --- Telegram ---
# 1. Abra o Telegram e procure por @BotFather
# 2. /newbot → escolha um nome → copie o token abaixo
TELEGRAM_BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 3. Abra uma conversa com seu bot e mande qualquer mensagem
# 4. Acesse: https://api.telegram.org/bot<TOKEN>/getUpdates
# 5. Copie o valor de "chat" → "id"
TELEGRAM_CHAT_ID=123456789

# --- brapi.dev (dados de FIIs) ---
# Token gratuito: cadastre em https://brapi.dev e gere um token
BRAPI_TOKEN=seu_token_brapi
BRAPI_BASE_URL=https://brapi.dev/api

# --- Watchlist e configuração de FIIs ---
FII_WATCHLIST=KNCR11,MXRF11,HSML11,BRCO11,LVBI11
FII_WEEKLY_BUDGET=500.00
FII_REINVEST_PROVENTOS=true
FII_CRON_HOUR=10

# --- Thresholds das regras (opcionais — valores padrão já configurados) ---
FII_MIN_DY=8.0
FII_MAX_PVP=1.15
FII_PVP_DISCOUNT=0.80
FII_MAX_VACANCIA=15.0
FII_MAX_LTV=70.0
FII_MIN_LIQUIDEZ=500000
FII_MAX_PRICE_DROP=5.0
FII_MIN_DELTA_DY=-1.0
